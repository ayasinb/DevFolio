@model DevFolio.Models.TblSocialMedia
@{
    ViewBag.Title = "SocialMediaUpdate";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<h2>Sosyal Medya Güncelle</h2>

<br />
<div class="container">

    @using (Html.BeginForm("SocialMediaUpdate", "SocialMedia", FormMethod.Post))
    {
        <form class="form-group" method="post">
            @Html.HiddenFor(x =>x.SocialMediaID)
            @Html.HiddenFor(x => x.SocialMediaStatus)
            <label>Platform Adı</label>
            @Html.TextBoxFor(x => x.SocialMediaPlatformName, new { @class = "form-control" })
            <br />
            <label>Simge Adresi</label>
            @Html.TextBoxFor(x => x.SocialMediaIconURL, new { @class = "form-control" })
            <br />
            <label>Hesap Adresi</label>
            @Html.TextBoxFor(x => x.SocialMediaRedirectURL, new { @class = "form-control" })
            <br />

            <button class="btn btn-primary">Güncelle</button>
        </form>}

</div>


